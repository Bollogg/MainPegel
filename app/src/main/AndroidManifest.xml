<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools">

  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.VIBRATE" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

  <application
    android:allowBackup="true"
    android:dataExtractionRules="@xml/data_extraction_rules"
    android:fullBackupContent="@xml/backup_rules"
    android:icon="@mipmap/ic_launcher_aal"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/ic_launcher_aal_round"
    android:supportsRtl="true"
    android:theme="@style/Theme.MainPegel">
    <activity
      android:name=".DatenschutzerklaerungActivity"
      android:exported="false"
      android:theme="@style/Theme.MainPegel" />
    <activity
      android:name=".Datenschutzerklaerung"
      android:exported="false" />
    <activity
      android:name=".MainActivity"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />

        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>
    <activity
      android:name=".SettingsActivity"
      android:exported="false" />
    <activity
      android:name=".InfoActivity"
      android:exported="false" />
    <activity
      android:name="com.google.android.gms.oss.licenses.OssLicensesMenuActivity"
      android:theme="@style/Theme.MainPegel.Oss" />
    <activity
      android:name="com.google.android.gms.oss.licenses.OssLicensesActivity"
      android:theme="@style/Theme.MainPegel" />

    <receiver
      android:name=".Widget.PegelWidget"
      android:exported="true">
      <intent-filter>
        <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
        <action android:name="de.net.wiesenfarth.mainpegel.UPDATE_WIDGET" />
      </intent-filter>

      <meta-data
        android:name="android.appwidget.provider"
        android:resource="@xml/pegel_widget_info" />
    </receiver>

    <service android:name=".Widget.WidgetUpdateService" />

    <receiver
      android:name=".AlarmManager.AlarmReceiver"
      android:exported="true" />

    <service
      android:name=".AlarmManager.PegelForegroundService"
      android:exported="false"
      android:foregroundServiceType="dataSync" />
    <meta-data
      android:name="preloaded_fonts"
      android:resource="@array/preloaded_fonts" />
  </application>

</manifest>