<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/main"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

    <!-- Toolbar oben -->
    <androidx.appcompat.widget.Toolbar
      android:id="@+id/toolbar"
      android:layout_width="0dp"
      android:layout_height="59dp"
      android:background="?attr/toolBarBackground"
      app:logo="@mipmap/ic_launcher_aal_round"
      app:title="@string/app_name"
      app:titleTextColor="?attr/colorToolbarText"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Chart -->
    <com.github.mikephil.charting.charts.LineChart
      android:id="@+id/lineChart"
      android:layout_width="0dp"
      android:layout_height="400dp"
      app:layout_constraintTop_toBottomOf="@id/toolbar"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zentrierter Bereich -->
    <LinearLayout
      android:id="@+id/content"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:layout_marginTop="16dp"
      android:gravity="center"
      android:orientation="vertical"

      app:layout_constraintTop_toBottomOf="@id/lineChart"
      app:layout_constraintBottom_toTopOf="@id/bottom_nav"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

        <TextView
          android:id="@+id/textViewPegelstand"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:fontFamily="sans-serif-condensed-light"
          android:text="@string/level_is_loading"
          android:textSize="18sp"
          android:textStyle="bold" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
      android:id="@+id/bottom_nav"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:background="?attr/toolBarBackground"
      app:menu="@menu/bottom_menu"
      app:itemIconTint="?attr/colorToolbarText"
      app:itemTextColor="?attr/colorToolbarText"

      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>